datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "../server/prisma"
}

model User {
  id                     String          @id
  kind                   String?
  name                   String
  email                  String
  enabled                Boolean
  status                 String
  password               String?
  confirmationCode       String?
  salt                   String?
  verifier               String?
  createdAt              DateTime
  updatedAt              DateTime
  provider               String?
  authorizationCode      String?
  codeChallenge          String?
  secretBlock            String?
  pubA                   String?
  pubB                   String?
  secB                   String?
  srpAuthTimestamp       String?
  srpAuthClientSignature String?
  preferredMfaSetting    String?
  enabledTotp            Boolean?
  totpSecretCode         String?
  tokens                 UserToken[]
  attributes             UserAttribute[]
  UserPool               UserPool        @relation(fields: [userPoolId], references: [id])
  userPoolId             String
}

model UserAttribute {
  id     String @id
  name   String
  value  String
  User   User   @relation(fields: [userId], references: [id])
  userId String
}

model UserPool {
  id              String           @id
  name            String?
  privateKey      String
  createdAt       DateTime
  users           User[]
  userPoolClients UserPoolClient[]
}

model UserPoolClient {
  id         String   @id
  name       String?
  createdAt  DateTime
  UserPool   UserPool @relation(fields: [userPoolId], references: [id])
  userPoolId String
}

model UserToken {
  id        String    @id
  kind      String
  token     String
  createdAt DateTime
  expiresAt DateTime
  revoked   Boolean
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id])
  userId    String
}
