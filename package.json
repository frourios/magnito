{
  "name": "magnito",
  "version": "0.0.0",
  "author": "Solufa <solufa2020@gmail.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "run-p dev:*",
    "dev:client": "next dev -p 5050",
    "dev:ssl": "local-ssl-proxy --key ./certificates/server.key --cert ./certificates/server.crt --source 5051 --target 5050",
    "dev:frourio": "frourio-next --watch",
    "dev:hcm": "hcm '**/*.module.css' -w",
    "dev:path": "pathpida --ignorePath .gitignore -s -w",
    "dev:prisma": "prisma generate --watch",
    "dev:msw": "frourio-next-msw --watch",
    "build": "prisma migrate deploy && npm run generate && next build",
    "generate": "run-p generate:*",
    "generate:frourio": "frourio-next && frourio-next-msw",
    "generate:path": "pathpida --ignorePath .gitignore -s",
    "generate:prisma": "prisma generate",
    "migrate:dev": "prisma migrate dev && npx prisma db seed",
    "migrate:dev:createonly": "prisma migrate dev --create-only",
    "migrate:deploy": "prisma migrate deploy && npx prisma db seed",
    "migrate:reset": "prisma migrate reset",
    "hcm": "hcm '**/*.module.css'",
    "start": "npm run start:client & npm run start:ssl",
    "start:client": "next start -p $PORT",
    "start:ssl": "local-ssl-proxy --key ./certificates/server.key --cert ./certificates/server.crt --source $SSL_PORT --target $PORT",
    "batch:writeVersion": "node batches/writeVersion.ts",
    "lint": "run-p lint:*",
    "lint:style": "stylelint \"**/*.css\" --ignore-path .gitignore",
    "lint:oxc": "oxlint && oxfmt --check",
    "fix:lint": "oxlint --fix && npm run lint:style -- --fix && oxfmt",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:updateSnapshot": "vitest -u",
    "typecheck": "npm run hcm && tsc --noEmit"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^6.15.2",
    "@aws-sdk/client-cognito-identity-provider": "^3.1009.0",
    "@fakerjs/word": "^1.0.1",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "aws-amplify": "^6.16.3",
    "dotenv": "^17.3.1",
    "fast-jwt": "^6.1.0",
    "get-jwks": "^11.0.3",
    "jotai": "^2.9.3",
    "jsbn": "^1.1.0",
    "local-ssl-proxy": "^2.0.5",
    "next": "^16.1.6",
    "node-jose": "^2.2.0",
    "otplib": "^13.3.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "swr": "^2.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@frourio/next": "^0.22.1",
    "@types/jsbn": "^1.2.33",
    "@types/node-jose": "^1.1.13",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.0",
    "happy-css-modules": "^3.1.1",
    "inbucket-js-client": "^2.0.0",
    "msw": "^2.12.10",
    "nodemailer": "^8.0.2",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "pathpida": "^0.26.0",
    "prisma": "^7.5.0",
    "stylelint": "^17.4.0",
    "stylelint-config-recess-order": "^7.6.1",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
