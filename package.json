  "license": "MIT",
  "scripts": {
    "notios": "notios dev",
    "dev": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "start": "npm start --prefix client",
    "generate": "npm run generate --prefix client",
    "batch:writeVersion": "node batches/writeVersion.ts",
    "lint": "run-p lint:*",
    "lint:style": "stylelint \"client/**/*.css\" --ignore-path .gitignore",
    "lint:oxc": "oxlint && oxfmt --check",
    "fix:lint": "oxlint --fix && npm run lint:style -- --fix && oxfmt",
    "test": "npm test --prefix client",
    "typecheck": "npm run typecheck --prefix client"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "notios": "^0.5.3",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "react": "^18.3.1",
    "stylelint": "^17.4.0",
    "stylelint-config-recess-order": "^7.6.1",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
