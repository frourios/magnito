{
  "name": "magnito",
  "version": "0.0.0",
  "author": "Solufa <solufa2020@gmail.com>",
  "license": "MIT",
  "scripts": {
    "notios": "notios dev",
    "dev": "run-p dev:*",
    "dev:client": "npm run dev --prefix client",
    "dev:server": "npm run dev --prefix server",
    "build": "run-p build:*",
    "build:client": "npm run build --prefix client",
    "build:server": "npm run build --prefix server",
    "start": "npm start --prefix client & npm start --prefix server",
    "generate": "run-p generate:*",
    "generate:client": "npm run generate --prefix client",
    "generate:server": "npm run generate --prefix server",
    "batch:writeVersion": "node batches/writeVersion.ts",
    "lint": "run-p lint:*",
    "lint:style": "stylelint \"client/**/*.css\" --ignore-path .gitignore",
    "lint:oxc": "oxlint && oxfmt --check",
    "lint:server": "npm run lint --prefix server",
    "fix:lint": "oxlint --fix && npm run lint:style -- --fix && oxfmt",
    "test": "run-p test:*",
    "test:client": "npm test --prefix client",
    "test:server": "npm test --prefix server",
    "typecheck": "run-p typecheck:*",
    "typecheck:client": "npm run typecheck --prefix client",
    "typecheck:server": "npm run typecheck --prefix server"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.5",
    "notios": "^0.5.3",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "react": "^18.3.1",
    "stylelint": "^17.4.0",
    "stylelint-config-recess-order": "^7.6.1",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
